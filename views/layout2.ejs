							<h3 style="margin:0!important;line-height:1.1em;">Campus Venâncio Aires</h3>
						</div>
						<div class="linha"></div>
						<img class="icone-info" src="alpha/images/alunos.png" width="40px" height="40px" style="margin-right: 1%">
